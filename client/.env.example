# =====================================================
# CLIENT ENVIRONMENT CONFIGURATION
# =====================================================

# Backend API URL (only needed if you deploy the Express server separately).
# On Vercel without a backend, the app uses built-in serverless routes + demo mode.
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=StockSim

# ---- OPTIONAL: server-side fallback API keys ----
# Users normally add their own keys in the in-app "API Keys" page (stored in
# their browser). These env vars are only used as a fallback default.
#
# NVIDIA NIM (AI analysis) - https://build.nvidia.com/
# NVIDIA_API_KEY=

# Finnhub (real-time stock data) - https://finnhub.io
# FINNHUB_API_KEY=

# stockdata.org (free real-time US quotes from IEX) - https://www.stockdata.org
# STOCKDATA_API_KEY=

# Alpha Vantage (stock data) - https://www.alphavantage.co
# ALPHA_VANTAGE_API_KEY=

# StockFit (company fundamentals from SEC filings) - https://developer.stockfit.io
# NOTE: fundamentals only, not real-time prices
# STOCKFIT_API_KEY=
