# =====================================================
# SERVER ENVIRONMENT CONFIGURATION
# Copy this file to .env and update values
# =====================================================

# Application
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/stock-trading-simulator

# JWT Security (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (for session/cache - optional)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:3000

# Stock Market API (Alpha Vantage)
STOCK_API_KEY=demo
STOCK_API_BASE_URL=https://www.alphavantage.co/query

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_SALT_ROUNDS=12

# NVIDIA NIM API (MiniMax-M3 for AI analysis)
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here
